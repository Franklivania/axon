# Neon PostgreSQL database connection string
DATABASE_URL="postgresql://user:password@hostname/dbname?sslmode=require"

# Secret key used for AES-256-GCM encryption of Solana wallet private keys
# Must be kept secret. In production, this should ideally be a random 32+ character string.
ENCRYPTION_SECRET="your_secure_encryption_secret_here"
# Solana RPC endpoint (devnet for development)
SOLANA_RPC_URL="https://api.devnet.solana.com"

# Wallet storage mode: "file" stores encrypted keys in data/wallets/ (development default)
# Use "db" for serverless/production environments (keys stored in Neon wallets table)
WALLET_STORAGE="file"
